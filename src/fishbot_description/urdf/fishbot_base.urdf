<?xml version="1.0"?>
<robot name="fishbot">
  
  <!-- ================= BASE LINK (身体) ================= -->\
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.12" radius="0.10"/>
      </geometry>
      <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.12" radius="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <!-- origin z原本是0，改成负数，比如 -0.05，让重心下沉 -->
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
    <!-- IMU 实体 Link -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- 固定在底盘上 -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.02"/>
  </joint>
  <!-- ================= LASER LINK (雷达) ================= -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 0.8" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
      <parent link="base_link" />
      <child link="laser_link" />
      <origin xyz="0 0 0.075" />
  </joint>
  <!-- ================= CASTER WHEEL (万向轮) ================= -->
  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
          <sphere radius="0.015"/> <!-- 半径比主轮小 -->
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
          <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
        <!-- 原来可能是 0.08，我们把它改大，比如 0.15 或者更远 -->
        <!-- 如果你的车身只有 0.1 半径，可以把万向轮放远一点，假装有个支架 -->
    <origin xyz="0.12 0 -0.065" rpy="0 0 0"/>
  </joint>
  <!-- ================= WHEELS (轮子) ================= -->
  
  <!-- 左轮 -->
  <link name="left_wheel_link">
      <visual>
        <!-- 【核心修改】这里必须是 0 0 0，因为关节已经旋转过了 -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.04" radius="0.03"/>
        </geometry>
        <material name="black">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <!-- 【核心修改】这里也必须是 0 0 0 -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.04" radius="0.03"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
  </link>
  
  <joint name="left_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="left_wheel_link"/>
      <axis xyz="0 0 1"/>
      <!-- 关节这里的 -1.57 (90度) 负责把轮子横过来，保持不动 -->
      <origin xyz="0 0.1 -0.05" rpy="-1.57079 0 0"/>
  </joint>

  <!-- 右轮 -->
  <link name="right_wheel_link">
      <visual>
        <!-- 【核心修改】这里必须是 0 0 0 -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.04" radius="0.03"/>
        </geometry>
        <material name="black">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <!-- 【核心修改】这里也必须是 0 0 0 -->
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.04" radius="0.03"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="right_wheel_link"/>
      <axis xyz="0 0 1"/>
      <!-- 关节这里的 -1.57 (90度) 负责把轮子横过来，保持不动 -->
      <origin xyz="0 -0.1 -0.05" rpy="-1.57079 0 0"/>
  </joint>
  <!-- ================= GAZEBO PLUGINS (核心) ================= -->
  
  <gazebo>
    <!-- 1. 差速驱动插件：负责发布 /odom 和 /tf -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.2</wheel_separation>
      <wheel_radius>0.03</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      
      <!-- 话题设置 -->
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      
      <!-- 坐标系设置 -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- 关节状态发布插件：告诉 ROS 轮子转到哪了 -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic> <!-- Gazebo 内部话题名 -->
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- 2. 雷达插件配置 -->
  <gazebo reference="laser_link">
    <!--  关节状态发布插件 (修复轮子 TF 报错的关键) -->
    <!-- 它负责把轮子的转动角度发送出来 -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic> <!-- Gazebo 内部话题名 -->
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
    <sensor name="laser_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <frame_id>laser_link</frame_id>
      <gz_frame_id>laser_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.000000</resolution>
            <min_angle>0.000000</min_angle>
            <max_angle>6.280000</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.120000</min>
          <max>3.5</max>
          <resolution>0.015000</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="base_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/White</material>
  </gazebo>

  <!-- IMU 传感器插件 -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
      </plugin>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      
      <!-- 【核心修复】强制指定 frame_id，防止 Cartographer 找不到 -->
      <frame_id>imu_link</frame_id>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

<!-- 增加轮子摩擦力，防止打滑 -->
  <gazebo reference="left_wheel_link">
    <mu1>200.0</mu1>   <!-- 切向摩擦系数 -->
    <mu2>100.0</mu2>   <!-- 法向摩擦系数 -->
    <kp>1000000.0</kp> <!-- 刚度系数 -->
    <kd>1.0</kd>       <!-- 阻尼系数 -->
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <mu1>200.0</mu1>
    <mu2>100.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- 万向轮必须是光滑的 -->
  <gazebo reference="caster_link">
    <mu1>0.0</mu1> <!-- 切向摩擦系数为0 -->
    <mu2>0.0</mu2> <!-- 法向摩擦系数为0 -->
    <material>Gazebo/Black</material>
  </gazebo>
</robot>